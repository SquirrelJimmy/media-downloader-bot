APP_CONFIG_PATH=config/app.yaml
DATABASE_URL=file:data/app.db
NEXT_PUBLIC_APP_NAME=Telegram Download Console

# Console auth. Set CONSOLE_PASSWORD for both local development and production.
# If empty, the console and business APIs are locked.
CONSOLE_PASSWORD=
CONSOLE_SESSION_TTL_DAYS=30
CONSOLE_COOKIE_SECURE=0

# Optional: BullMQ queue backend. Leave empty to use the in-memory queue.
REDIS_URL=

# Optional: external tools.
YTDLP_PATH=yt-dlp
RCLONE_PATH=rclone
